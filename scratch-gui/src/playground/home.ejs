<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="google" value="notranslate">
    <meta name="description" content="<%= htmlWebpackPlugin.options.APP_NAME %> is a Scratch-style 3D editor for making model actors, camera movement, lights, and 3D worlds with simple blocks.">
    <title><%= htmlWebpackPlugin.options.title %></title>
    <link rel="icon" href="<%= htmlWebpackPlugin.options.root %>favicon.ico">
    <link rel="apple-touch-icon" href="<%= htmlWebpackPlugin.options.root %>images/apple-touch-icon.png">
    <% if (htmlWebpackPlugin.options.root === "/" || htmlWebpackPlugin.options.root === "") { %>
      <link rel="manifest" href="<%= htmlWebpackPlugin.options.root %>manifest.webmanifest">
    <% } %>
    <style>
      :root {
        --accent: #8169ff;
        --ink: #16141a;
        --muted: #5f5867;
        --line: rgba(22, 20, 26, 0.14);
        --surface: #ffffff;
        --soft: #f5eff9;
        --blue: #2f80ed;
        --green: #2aa56a;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
      }

      body {
        margin: 0;
        background: var(--surface);
        color: var(--ink);
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        letter-spacing: 0;
      }

      a {
        color: inherit;
      }

      .shell {
        min-height: 100vh;
        overflow: hidden;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        width: min(1120px, calc(100% - 36px));
        min-height: 68px;
        margin: 0 auto;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--ink);
        font-weight: 800;
        text-decoration: none;
      }

      .brand img {
        width: 34px;
        height: 34px;
        object-fit: contain;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 18px;
        color: var(--muted);
        font-size: 0.92rem;
        font-weight: 700;
      }

      .nav-links a {
        text-decoration: none;
      }

      .nav-links a:hover {
        color: var(--accent);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.02fr) minmax(280px, 0.78fr);
        align-items: center;
        gap: clamp(28px, 6vw, 82px);
        width: min(1120px, calc(100% - 36px));
        min-height: calc(100vh - 168px);
        margin: 0 auto;
        padding: 38px 0 54px;
      }

      .hero-copy {
        max-width: 680px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 18px;
        color: var(--accent);
        font-size: 0.82rem;
        font-weight: 800;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 28px;
        height: 4px;
        border-radius: 999px;
        background: var(--accent);
      }

      h1 {
        max-width: 680px;
        margin: 0;
        color: var(--ink);
        font-size: clamp(3.2rem, 9vw, 6.9rem);
        line-height: 0.92;
        letter-spacing: 0;
      }

      .tagline {
        max-width: 620px;
        margin: 22px 0 0;
        color: var(--muted);
        font-size: clamp(1.06rem, 2.1vw, 1.34rem);
        line-height: 1.55;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 30px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border: 2px solid var(--ink);
        border-radius: 8px;
        background: var(--surface);
        color: var(--ink);
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 4px 0 var(--ink);
      }

      .button:hover {
        transform: translateY(-1px);
        box-shadow: 0 5px 0 var(--ink);
      }

      .button:active {
        transform: translateY(3px);
        box-shadow: 0 1px 0 var(--ink);
      }

      .button.primary {
        background: var(--accent);
        color: #fff;
      }

      .hero-art {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 360px;
      }

      .preview-plate {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: min(520px, 78vw);
        aspect-ratio: 4 / 3;
        overflow: hidden;
        border: 2px solid var(--ink);
        border-radius: 18px;
        background: var(--soft);
        box-shadow: 12px 12px 0 var(--ink);
      }

      .preview-plate img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .peek {
        border-top: 1px solid var(--line);
        background: #fafafa;
      }

      .peek-inner {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        width: min(1120px, calc(100% - 36px));
        margin: 0 auto;
        color: var(--muted);
      }

      .peek-item {
        min-height: 92px;
        padding: 18px 18px 20px 0;
      }

      .peek-item strong {
        display: block;
        margin-bottom: 5px;
        color: var(--ink);
        font-size: 0.98rem;
      }

      .peek-item span {
        font-size: 0.9rem;
        line-height: 1.4;
      }

      @media (max-width: 820px) {
        .nav {
          min-height: 62px;
        }

        .nav-links {
          gap: 12px;
          font-size: 0.86rem;
        }

        .hero {
          grid-template-columns: 1fr;
          min-height: auto;
          padding-top: 26px;
        }

        .hero-art {
          order: -1;
          min-height: 250px;
        }

        .icon-plate {
          width: min(300px, 78vw);
          border-radius: 18px;
          box-shadow: 8px 8px 0 var(--ink);
        }

        .axis {
          right: -8px;
          bottom: 16px;
        }

        .peek-inner {
          grid-template-columns: 1fr;
        }

        .peek-item {
          min-height: 0;
          padding-right: 0;
          border-bottom: 1px solid var(--line);
        }
      }

      @media (max-width: 520px) {
        .nav {
          width: min(100% - 24px, 1120px);
        }

        .nav-links a:nth-child(2) {
          display: none;
        }

        .hero,
        .peek-inner {
          width: min(100% - 24px, 1120px);
        }

        .button {
          flex: 1 1 100%;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <nav class="nav" aria-label="Main">
        <a class="brand" href="<%= htmlWebpackPlugin.options.root %>">
          <img src="<%= htmlWebpackPlugin.options.root %>images/amethyst-icon-original.png" alt="">
          <span><%= htmlWebpackPlugin.options.APP_NAME %></span>
        </a>
        <div class="nav-links">
          <a href="<%= htmlWebpackPlugin.options.root %>editor.html">Editor</a>
          <a href="https://github.com/Amethyst-official/amethyst#readme">Docs</a>
          <a href="https://github.com/Amethyst-official/amethyst">Source</a>
        </div>
      </nav>

      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <div class="eyebrow">Scratch in 3D</div>
          <h1 id="hero-title"><%= htmlWebpackPlugin.options.APP_NAME %></h1>
          <p class="tagline">
            Build 3D worlds with model actors, camera blocks, lights, environments, and kid-friendly Scratch-style code.
          </p>
          <div class="actions">
            <a class="button primary" href="<%= htmlWebpackPlugin.options.root %>editor.html">Open Editor</a>
            <a class="button" href="https://github.com/Amethyst-official/amethyst#readme">Read Docs</a>
          </div>
        </div>

        <div class="hero-art" aria-hidden="true">
          <div class="preview-plate">
            <img src="<%= htmlWebpackPlugin.options.root %>images/amethyst-preview.png" alt="">
          </div>
        </div>
      </section>

      <section class="peek" aria-label="Amethyst focus areas">
        <div class="peek-inner">
          <div class="peek-item">
            <strong>Blocks</strong>
            <span>Motion, camera, environment, mouse, media, and network tools shaped for 3D projects.</span>
          </div>
          <div class="peek-item">
            <strong>Models</strong>
            <span>Import model actors and keep costume editing inside the app instead of jumping to complex tools.</span>
          </div>
          <div class="peek-item">
            <strong>Worlds</strong>
            <span>Use sky, fog, ground, lighting, and infinite 3D space as first-class project pieces.</span>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
